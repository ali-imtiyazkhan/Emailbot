# Server Config
PORT=3000
DATABASE_URL="postgresql://postgres:password@localhost:5432/emailbot?schema=public"
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
BASE_URL=http://localhost:3001

# Gmail OAuth
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:3001/auth/gmail/callback

# Outlook OAuth
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=http://localhost:3001/auth/outlook/callback

# Meta WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_RECIPIENT_PHONE=your_phone_number_for_notifications

# AI Service
ANTHROPIC_API_KEY=your_claude_api_key
